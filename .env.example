# Virtual Science Lab – Environment Variables
# Copy this file to .env and fill in your values.
# The chatbot works without any keys (mock mode).
# Add a key to switch to a real AI provider.

# ── OpenAI ──────────────────────────────────────────────────
# Enables GPT-4o-mini responses in the chatbot.
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Google Gemini ────────────────────────────────────────────
# Enables Gemini Pro responses in the chatbot.
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# ── Frontend (Vite) ──────────────────────────────────────────
# Override the backend URL if you deploy elsewhere.
# VITE_API_BASE_URL=https://your-backend.onrender.com

# ── MongoDB ──────────────────────────────────────────────────
# Database connection string (defaults to local MongoDB if unset).
# MONGODB_URI=mongodb://localhost:27017/virtual_science_lab

